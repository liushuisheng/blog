---
import LegacyRedirect from '../../../../components/LegacyRedirect.astro';
export function getStaticPaths() {
  return [
    { params: { slug: 'hello-world' }, props: { target: '/articles/hello-world/' } },
    { params: { slug: '随便整点啥' }, props: { target: '/articles/' } },
    { params: { slug: '测试一下草稿布局' }, props: { target: '/articles/' } }
  ];
}
const { target } = Astro.props;
---
<LegacyRedirect target={target} />
