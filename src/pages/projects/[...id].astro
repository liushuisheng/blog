---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { withBase } from '../../data/site';
export async function getStaticPaths() {
  return (await getCollection('projects')).map((project) => ({ params: { id: project.id }, props: { project } }));
}
const { project } = Astro.props;
const { Content } = await render(project);
---
<BaseLayout title={project.data.title} description={project.data.summary}>
  <article class="container project-detail">
    <a class="back" href={withBase('/projects/')}>← 返回作品集</a>
    <header><p class="eyebrow">{project.data.year} · {project.data.status}</p><h1 class="page-title">{project.data.title}</h1><p class="lead">{project.data.summary}</p></header>
    <div class="facts card"><div><span>角色</span><strong>{project.data.role}</strong></div><div><span>技术栈</span><strong>{project.data.stack.join(' · ')}</strong></div><div class="links">{project.data.demo && <a href={project.data.demo}>在线体验 ↗</a>}{project.data.repository && <a href={project.data.repository}>查看源码 ↗</a>}</div></div>
    {project.data.highlights.length > 0 && <section class="highlights"><p class="eyebrow">项目亮点</p><div>{project.data.highlights.map((item) => <strong>{item}</strong>)}</div></section>}
    <div class="prose"><Content /></div>
  </article>
</BaseLayout>
<style>
  .project-detail { padding: 56px 0; }.back { color: var(--muted); }.project-detail header { margin: 48px 0 32px; max-width: 820px; }.lead { color: var(--muted); font-size: 1.05rem; }.facts { display: grid; grid-template-columns: .7fr 1.3fr 1fr; gap: 22px; padding: 22px; margin-bottom: 40px; }.facts div { display: flex; flex-direction: column; }.facts span { color: var(--muted); font-size: .78rem; }.links { align-items: end; }.links a { color: var(--accent); font-weight: 700; }.highlights { margin: 34px 0 46px; }.highlights div { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }.highlights strong { padding: 18px; border-top: 2px solid var(--warm); background: rgba(255,255,255,.35); }.prose { padding-top: 20px; border-top: 1px solid var(--line); } @media(max-width:700px){.project-detail{padding:32px 0 44px}.back{display:inline-flex;align-items:center;min-height:40px}.project-detail header{margin:27px 0 25px}.lead{font-size:.95rem;line-height:1.75}.facts,.highlights div{grid-template-columns:1fr}.facts{gap:16px;padding:19px;margin-bottom:30px}.facts strong{overflow-wrap:anywhere}.links{align-items:start;gap:8px}.highlights{margin:28px 0 34px}.highlights strong{padding:16px}.prose{padding-top:15px}}
</style>
