---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../data/site';

const projects = (await getCollection('projects')).filter((item) => item.data.featured).sort((a, b) => b.data.year - a.data.year);
const project = projects[0];
const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()).slice(0, 4);
const date = (value: Date) => `${value.getFullYear()}.${String(value.getMonth() + 1).padStart(2, '0')}.${String(value.getDate()).padStart(2, '0')}`;
const stackName: Record<string, string> = { Astro: '静态网站', TypeScript: '类型脚本', Markdown: '内容标记', 'GitHub Actions': '自动部署' };
---
<BaseLayout>
  <section class="intro container reveal">
    <div class="intro-copy">
      <div class="availability"><i></i><span>AI 全栈开发者</span></div>
      <h1>AI 应用开发，<br /><span>项目和笔记。</span></h1>
      <p>做项目，写技术笔记。</p>
      <div class="intro-actions"><a class="button primary" href={withBase('/projects/')}>看看项目 ↗</a><a href={withBase('/blog/')}>看看文章 <span>→</span></a></div>
    </div>

    <div class="code-window" data-tilt>
      <div class="code-top"><div><i></i><i></i><i></i></div><span>coding</span><b>实时</b></div>
      <div class="code-body">
        <div class="line"><code><span class="purple">const</span> focus = {'{'}</code></div>
        <div class="line"><code>&nbsp;&nbsp;role: <span class="green">'AI Full-Stack'</span>,</code></div>
        <div class="line"><code>&nbsp;&nbsp;building: [</code></div>
        <div class="line pulse"><code>&nbsp;&nbsp;&nbsp;&nbsp;<span class="green">'Agents'</span>, <span class="green">'RAG'</span>, <span class="green">'Web Apps'</span></code></div>
        <div class="line"><code>&nbsp;&nbsp;],</code></div>
        <div class="line"><code>&nbsp;&nbsp;status: <span class="lime">'shipping'</span></code></div>
        <div class="line"><code>{'}'}<span class="caret"></span></code></div>
      </div>
      <div class="code-status"><span>运行中</span><span>持续更新</span></div>
    </div>
  </section>

  <section class="workspace container reveal">
    <div class="workspace-grid">
      <div class="project-column">
        <div class="work-head"><div><p>精选项目</p></div></div>
        {project && <article class="featured" data-tilt>
          <div class="featured-visual"><div class="project-kicker"><b>项目案例</b><time>{project.data.year}</time></div><div class="visual-shape"><i></i><i></i><i></i></div><div class="visual-flow"><span>开发</span><span>上线</span><span>复盘</span></div></div>
          <div class="featured-copy"><div class="project-meta"><span>{project.data.status}</span><span>{project.data.role}</span></div><h2>{project.data.title}</h2><p>旧博客重构：内容、结构与发布流程。</p><div class="stack">{project.data.stack.map((item) => <span>{stackName[item] ?? item}</span>)}</div><div class="project-actions"><a href={withBase(`/projects/${project.id}/`)}><b>查看项目 <i>↗</i></b></a><a href={withBase('/projects/')}>全部作品 →</a></div></div>
        </article>}
      </div>

      <aside class="notes">
        <div class="notes-head"><div><p>最近文章</p></div></div>
        <div class="note-list">{posts.map((post) => <a href={withBase(`/blog/${post.id}/`)}><div><time>{date(post.data.updatedAt ?? post.data.publishedAt)}</time><h3>{post.data.title}</h3></div><i>↗</i></a>)}</div>
        <a class="notes-more" href={withBase('/blog/')}>浏览全部文章 <span>→</span></a>
      </aside>
    </div>
  </section>

  <section class="focus-section reveal">
    <div class="container">
      <div class="focus-heading"><div><p>关注方向</p><h2>最近在做</h2></div></div>
      <div class="focus-grid">
        <article data-focus-card><i></i><h3>AI 应用</h3><p>模型接入、智能体与检索增强。</p><span>相关文章 <b>→</b></span></article>
        <article data-focus-card><i></i><h3>全栈开发</h3><p>界面、接口、数据与部署。</p><span>相关文章 <b>→</b></span></article>
        <article data-focus-card><i></i><h3>工程实践</h3><p>性能、自动化与开发工具。</p><span>相关文章 <b>→</b></span></article>
        <article data-focus-card><i></i><h3>项目复盘</h3><p>问题、取舍与结果。</p><span>相关文章 <b>→</b></span></article>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .intro { position: relative; display: grid; grid-template-columns: 1.02fr .98fr; align-items: center; gap: clamp(45px,8vw,110px); min-height: 480px; padding-block: 56px; }
  .intro::after { content: ''; position: absolute; z-index: -1; width: 360px; height: 360px; right: 4%; border-radius: 50%; border: 1px solid rgba(20,20,20,.07); box-shadow: 0 0 0 48px rgba(20,20,20,.018),0 0 0 96px rgba(20,20,20,.012); }
  .availability { display: flex; align-items: center; gap: 10px; font-size: .78rem; line-height: 1.4; font-weight: 680; letter-spacing: .035em; }.availability i { width: 8px; height: 8px; border-radius: 50%; background: var(--warm); box-shadow: 0 0 0 5px rgba(184,255,50,.18); }.availability b { margin-left: auto; color: var(--muted); font-weight: 580; }
  h1 { margin: 19px 0 18px; font-size: clamp(2.7rem,5.2vw,4.65rem); line-height: 1.08; font-weight: 780; letter-spacing: -.045em; }.intro h1 span { position: relative; white-space: nowrap; }.intro h1 span::after { content: ''; position: absolute; height: 9px; left: 1px; right: -4px; bottom: 3px; z-index: -1; background: var(--warm); transform: rotate(-1.5deg); }
  .intro-copy>p { max-width: 610px; margin: 0; color: var(--muted); font-size: .98rem; }.intro-actions { display: flex; align-items: center; gap: 24px; margin-top: 25px; }.intro-actions>a:not(.button) { font-size: .88rem; font-weight: 700; }.intro-actions>a:not(.button):hover span { display: inline-block; transform: translateX(4px); }
  .code-window { overflow: hidden; color: #e8e8e1; border: 1px solid #2d2d2a; border-radius: 12px; background: var(--warm); box-shadow: 14px 16px 0 rgba(184,255,50,.18); font-family: ui-monospace,SFMono-Regular,Consolas,"Noto Sans SC Variable",monospace; }
  .code-top { height: 42px; padding: 0 16px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; color: #aaa9a2; border-bottom: 1px solid #30302d; background: #1c1c1a; font-family:"Noto Sans SC Variable",sans-serif;font-size: .76rem; }.code-top div { display:flex;gap:6px }.code-top i { width:8px;height:8px;border-radius:50%;background:#ff6159 }.code-top i:nth-child(2){background:#ffbd2e}.code-top i:nth-child(3){background:#28c941}.code-top b{justify-self:end;font-weight:500}
  .code-body { position: relative; padding: 23px 0; background:#151514; font-size: .86rem; line-height: 1.82; }.code-body::after { content: ''; position: absolute; inset: 0; pointer-events:none; background: linear-gradient(transparent 49%,rgba(184,255,50,.04) 50%,transparent 51%); background-size:100% 6px; }.line { display:grid;grid-template-columns:42px 1fr;padding:0 18px }.line em{color:#55554f;font-style:normal;user-select:none}.line code{font:inherit}.purple{color:#b9adff}.green{color:#9aebc8}.lime{color:var(--warm)}.caret{display:inline-block;width:7px;height:15px;margin-left:5px;vertical-align:-2px;background:var(--warm);animation:blink 1s steps(1) infinite}.pulse{animation:codePulse 3.4s ease-in-out infinite}
  .code-status { display:flex;justify-content:space-between;padding:8px 15px 9px;color:#151514;background:var(--warm);border-radius:0 0 12px 12px;font-family:"Noto Sans SC Variable",sans-serif;font-size:.74rem;line-height:1.35;font-weight:680 }.code-status span:first-child{display:flex;align-items:center;gap:7px;animation:statusPulse 1.8s ease-in-out infinite}.code-status span:first-child::before{content:'';width:8px;height:8px;border-radius:50%;background:#6b63e8}
  @keyframes blink{50%{opacity:0}}@keyframes codePulse{50%{background:rgba(184,255,50,.065)}}@keyframes statusPulse{50%{opacity:.55}}
  .workspace { padding-block: 58px 64px; border-top: 1px solid var(--line); }.work-head,.notes-head { display:flex;align-items:center;margin-bottom:20px }.work-head div,.notes-head div{display:flex;align-items:center;gap:10px}.work-head span,.notes-head span{display:grid;place-items:center;width:27px;height:27px;color:white;background:var(--ink);border-radius:50%;font:700 .7rem/1 ui-monospace,monospace}.work-head p,.notes-head p{margin:0;font-size:.86rem;font-weight:700;letter-spacing:.025em}
  .workspace-grid { display:grid;grid-template-columns:minmax(0,1.2fr) minmax(340px,.8fr);gap:24px }.featured { display:grid;grid-template-columns:.85fr 1.15fr;overflow:hidden;min-height:390px;border:1px solid var(--line);border-radius:18px;background:white;box-shadow:0 20px 60px rgba(20,20,20,.065);transform-style:preserve-3d}.featured-visual{position:relative;overflow:hidden;padding:22px;color:white;background:#151514}.featured-visual>span,.featured-visual code{position:relative;z-index:2;font:650 .62rem/1 ui-monospace,monospace;letter-spacing:.1em}.featured-visual>strong{position:absolute;right:-8px;top:-30px;font-size:9rem;line-height:1;color:rgba(255,255,255,.06)}.featured-visual code{position:absolute;left:22px;bottom:22px;color:var(--warm)}.rings{position:absolute;inset:0}.rings i{position:absolute;left:50%;top:50%;width:150px;height:150px;border:1px solid rgba(184,255,50,.45);border-radius:50%;transform:translate(-50%,-50%)}.rings i:nth-child(2){width:230px;height:230px}.rings i:nth-child(3){width:310px;height:310px}.featured:hover .rings{transform:rotate(12deg);transition:transform .7s ease}.featured-copy{padding:30px}.project-meta{display:flex;justify-content:space-between;color:var(--muted);font-size:.7rem}.featured h2{margin:42px 0 11px;font-size:clamp(1.55rem,3vw,2.3rem);line-height:1.12;letter-spacing:-.045em}.featured-copy>p{color:var(--muted);font-size:.9rem}.stack{display:flex;flex-wrap:wrap;gap:6px;margin:21px 0 30px}.stack span{padding:4px 8px;border:1px solid var(--line);border-radius:5px;font:650 .65rem/1.3 ui-monospace,monospace}.project-actions{display:flex;align-items:center;gap:20px;font-size:.78rem}.project-actions a:last-child{color:var(--muted)}.project-actions b{font-size:.82rem}.project-actions i{display:inline-block;font-style:normal;transition:transform .2s}.project-actions a:first-child:hover i{transform:translate(4px,-4px)}.project-actions a:last-child:hover{color:var(--accent)}
  .notes { min-width:0 }.note-list{border-top:1px solid var(--line)}.note-list>a{display:grid;grid-template-columns:26px 1fr auto;gap:12px;padding:17px 3px;border-bottom:1px solid var(--line);transition:padding .2s,background .2s}.note-list>a:hover{padding-inline:12px;background:#f8f8f4}.note-list>a>span{color:#aaa;font:650 .65rem/1.7 ui-monospace,monospace}.note-list time{color:var(--muted);font-size:.62rem}.note-list h3{margin:2px 0 3px;font-size:.98rem;line-height:1.3;letter-spacing:-.02em}.note-list p{overflow:hidden;margin:0;color:var(--muted);font-size:.75rem;white-space:nowrap;text-overflow:ellipsis}.note-list>a>i{align-self:center;font-style:normal;transition:transform .2s}.note-list>a:hover>i{transform:translate(3px,-3px)}.notes-more{display:flex;align-items:center;justify-content:space-between;margin-top:14px;padding:10px 12px;border-radius:8px;color:var(--muted);font-size:.76rem;font-weight:650;transition:background .2s,color .2s}.notes-more:hover{color:var(--ink);background:var(--accent-soft)}.notes-more span{transition:transform .2s}.notes-more:hover span{transform:translateX(4px)}
  .focus-section{padding:72px 0 88px;border-top:1px solid var(--line);background:#f6fbf8}.focus-heading{display:grid;grid-template-columns:auto 1fr auto;align-items:end;gap:16px;margin-bottom:34px}.focus-heading>span{display:grid;place-items:center;width:27px;height:27px;color:#fff;background:var(--accent);border-radius:50%;font-size:.62rem;font-weight:700}.focus-heading div p{margin:0 0 5px;color:var(--accent);font-size:.72rem;font-weight:700}.focus-heading h2{margin:0;font-size:clamp(1.9rem,3vw,2.8rem);line-height:1.16;letter-spacing:-.03em}.focus-heading>p{max-width:330px;margin:0;color:var(--muted);font-size:.86rem}.focus-grid{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid var(--line);border-left:1px solid var(--line)}.focus-grid article{min-height:260px;padding:26px 24px;border-right:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(255,255,255,.72);transition:transform .25s ease,background .25s ease}.focus-grid article:hover{z-index:1;background:#fff;transform:translateY(-7px);box-shadow:0 18px 40px rgba(20,80,55,.08)}.focus-grid b{color:var(--accent);font-size:.68rem}.focus-grid h3{margin:38px 0 12px;font-size:1.25rem;letter-spacing:-.02em}.focus-grid p{margin:0;color:var(--muted);font-size:.8rem;line-height:1.75}.focus-grid span{display:block;margin-top:25px;font-size:.72rem;font-weight:650}
  .intro::after{border:0;box-shadow:none;background:radial-gradient(circle,rgba(20,134,95,.08),transparent 68%)}
  .code-window,.featured{border:0}.code-top{border-bottom:0}.workspace,.focus-section{border-top:0}
  .stack span{border:0;background:var(--accent-soft)}
  .note-list{display:grid;gap:8px;border-top:0}.note-list>a{padding:14px 12px;border-bottom:0;border-radius:10px;background:#fafcfb}.note-list>a:hover{background:var(--accent-soft)}
  .focus-grid{gap:12px;border:0}.focus-grid article{border:0;border-radius:14px}
  .intro{isolation:isolate}.intro::before{content:'';position:absolute;z-index:-1;left:-16%;top:8%;width:300px;height:300px;border-radius:42% 58% 63% 37%;background:linear-gradient(135deg,rgba(189,241,107,.28),rgba(89,218,183,.12));filter:blur(8px);animation:floatBlob 9s ease-in-out infinite}.intro::after{right:-2%;background:radial-gradient(circle at 35% 35%,rgba(107,99,232,.15),rgba(20,134,95,.08) 42%,transparent 70%);animation:floatBlob 11s ease-in-out infinite reverse}
  .code-window{position:relative;box-shadow:0 28px 80px rgba(18,38,30,.18),14px 16px 0 rgba(184,255,50,.18)}.code-window::after{content:'';position:absolute;width:110px;height:110px;right:-45px;top:-45px;border-radius:38% 62% 45% 55%;background:linear-gradient(135deg,#bdf16b,#65d7a8);opacity:.18;filter:blur(2px);animation:shapeTurn 8s linear infinite}.line{display:block;padding:0 28px}.line code{display:block}
  .work-head p,.notes-head p{position:relative;padding:4px 0 4px 13px;background:none;box-shadow:none}.work-head p::before,.notes-head p::before{content:'';position:absolute;left:0;top:50%;width:3px;height:14px;border-radius:99px;transform:translateY(-50%)}.work-head p::before{background:linear-gradient(180deg,var(--accent),var(--warm));box-shadow:0 4px 12px rgba(20,134,95,.22)}.notes-head p::before{background:linear-gradient(180deg,#6b63e8,#78b7ff);box-shadow:0 4px 12px rgba(107,99,232,.22)}
  .featured{position:relative;box-shadow:0 28px 80px rgba(38,69,55,.11)}.featured-visual{background:linear-gradient(145deg,#17231e,#101310)}.visual-shape{position:absolute;inset:0}.visual-shape i{position:absolute;border-radius:36% 64% 58% 42%;filter:saturate(1.1)}.visual-shape i:first-child{width:240px;height:240px;left:-45px;top:70px;background:linear-gradient(135deg,rgba(189,241,107,.9),rgba(20,134,95,.35));animation:floatBlob 7s ease-in-out infinite}.visual-shape i:nth-child(2){width:145px;height:145px;right:-30px;top:28px;background:linear-gradient(135deg,rgba(107,99,232,.85),rgba(58,207,163,.45));mix-blend-mode:screen;animation:shapeTurn 10s linear infinite}.visual-shape i:nth-child(3){width:70px;height:70px;left:48%;bottom:42px;background:var(--warm);opacity:.48;filter:blur(8px);animation:floatBlob 5s ease-in-out infinite reverse}
  .project-kicker{position:relative;z-index:3;display:inline-flex;align-items:center;gap:9px;padding:7px 10px;border-radius:9px;color:#f5fff9;background:rgba(8,18,14,.48);box-shadow:0 10px 30px rgba(0,0,0,.12);backdrop-filter:blur(10px);font-family:"Noto Sans SC Variable",sans-serif}.project-kicker b{font-size:.74rem;line-height:1.3;font-weight:680}.project-kicker time{padding:2px 6px;border-radius:5px;color:#17211c;background:var(--warm);font-size:.68rem;line-height:1.4;font-weight:750}.visual-flow{position:absolute;z-index:3;left:22px;bottom:22px;display:flex;gap:7px}.visual-flow span{display:inline-flex;align-items:center;gap:6px;padding:6px 9px;border-radius:8px;color:#f4fff8;background:rgba(8,18,14,.55);box-shadow:0 8px 24px rgba(0,0,0,.13);backdrop-filter:blur(10px);font-family:"Noto Sans SC Variable",sans-serif;font-size:.7rem;line-height:1.35;font-weight:620}.visual-flow span::before{content:'';width:6px;height:6px;border-radius:50%;background:#8fe1b9}.visual-flow span:nth-child(2)::before{background:#b9adff}.visual-flow span:nth-child(3)::before{background:var(--warm)}
  .note-list>a{grid-template-columns:1fr auto;box-shadow:0 10px 32px rgba(26,65,48,.045);transform:translateX(0)}.note-list>a:nth-child(even){margin-left:14px}.note-list>a:hover{transform:translateX(5px);box-shadow:0 16px 38px rgba(26,65,48,.09)}
  .focus-section{position:relative;overflow:hidden;background:linear-gradient(135deg,#f5fbf7 0%,#f8f7ff 55%,#fbfff4 100%)}.focus-section::before,.focus-section::after{content:'';position:absolute;border-radius:50%;filter:blur(4px);pointer-events:none}.focus-section::before{width:330px;height:330px;right:-100px;top:-120px;background:radial-gradient(circle,rgba(107,99,232,.12),transparent 68%)}.focus-section::after{width:280px;height:280px;left:-90px;bottom:-100px;background:radial-gradient(circle,rgba(189,241,107,.25),transparent 68%)}.focus-heading{grid-template-columns:1fr auto}.focus-grid{position:relative;z-index:1}.focus-grid article{position:relative;overflow:hidden;box-shadow:0 18px 48px rgba(34,78,58,.07)}.focus-grid article:nth-child(even){transform:translateY(18px)}.focus-grid article:nth-child(even):hover{transform:translateY(10px)}.focus-grid article>i{display:block;width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,var(--accent-soft),rgba(189,241,107,.7));box-shadow:0 10px 24px rgba(20,134,95,.12);transform:rotate(-8deg);transition:transform .3s ease}.focus-grid article:nth-child(2)>i{background:linear-gradient(135deg,#eeeaff,#b9c7ff)}.focus-grid article:nth-child(3)>i{background:linear-gradient(135deg,#fff2cc,#bdf16b)}.focus-grid article:nth-child(4)>i{background:linear-gradient(135deg,#d8f8ea,#b8e6ff)}.focus-grid article:hover>i{transform:rotate(8deg) scale(1.08)}.focus-grid h3{margin-top:25px}
  .project-meta{font-size:.78rem;line-height:1.5}.featured-copy>p{font-size:.94rem;line-height:1.75}.stack span{font-family:"Noto Sans SC Variable",sans-serif;font-size:.74rem;line-height:1.45;font-weight:620}.project-actions,.notes-more{font-size:.82rem}.note-list time{font-size:.72rem;line-height:1.5}.note-list h3{margin-top:4px;font-size:1.02rem;line-height:1.45}.focus-heading div p{font-size:.8rem;letter-spacing:.03em}.focus-grid p{font-size:.86rem;line-height:1.75}.focus-grid span{font-size:.78rem;line-height:1.5}
  .project-meta{justify-content:flex-start;align-items:center;gap:8px;flex-wrap:wrap;font-family:"Noto Sans SC Variable",sans-serif}.project-meta span{display:inline-flex;align-items:center;min-height:29px;padding:5px 10px;border-radius:9px;color:#526159;background:#eff7f3}.project-meta span:first-child{gap:7px;color:#147553;background:#e8f8f0;font-weight:650}.project-meta span:first-child::before{content:'';width:7px;height:7px;border-radius:50%;background:#36b97f;box-shadow:0 0 0 4px rgba(54,185,127,.1)}.project-meta span:last-child{color:#625d8c;background:#f1efff}
  .note-list time{display:inline-flex;width:max-content;align-items:center;padding:5px 9px;border-radius:8px;color:#527064;background:#e8f8f0;font-variant-numeric:tabular-nums;font-weight:620;letter-spacing:.025em}.note-list>a:nth-child(even) time{color:#625d8c;background:#efedff}.note-list h3{margin-top:8px}
  @keyframes floatBlob{0%,100%{transform:translate3d(0,0,0) rotate(0)}50%{transform:translate3d(10px,-18px,0) rotate(8deg)}}@keyframes shapeTurn{to{transform:rotate(360deg)}}
  @media(max-width:880px){.intro{grid-template-columns:1fr;min-height:auto;padding-block:42px;gap:38px}.code-window{max-width:650px;width:100%}.workspace-grid{grid-template-columns:1fr}.notes{margin-top:18px}.focus-grid{grid-template-columns:repeat(2,1fr)}.focus-heading{grid-template-columns:1fr}}
