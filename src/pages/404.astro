---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../data/site';
---
<BaseLayout title="页面未找到" description="你访问的页面不存在或已经移动。">
  <section class="container missing"><p class="eyebrow">404</p><h1 class="page-title">这里没有内容。</h1><p>页面可能已经移动，也可能从未存在。</p><a class="button primary" href={withBase('/')}>返回首页</a></section>
</BaseLayout>
<style>.missing{min-height:65vh;display:flex;flex-direction:column;align-items:flex-start;justify-content:center}.missing>p:not(.eyebrow){color:var(--muted);margin-bottom:25px}@media(max-width:720px){.missing{min-height:60vh;padding-block:40px}}</style>
