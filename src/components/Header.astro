---
import { site, withBase } from '../data/site';
const pathname = Astro.url.pathname;
---
<header class="site-header">
  <div class="container nav-wrap">
    <a class="brand" href={withBase('/')} aria-label="返回首页">
      <span class="brand-mark" aria-hidden="true"><img src={withBase('/brand-logo-transparent.png')} alt="" /></span>
      <span class="brand-copy"><strong>{site.brand}</strong><small>记录AI学习 · 探索AI应用</small></span>
    </a>
    <nav aria-label="主导航">
      {site.nav.map((item) => (
        <a class:list={{ active: item.href === '/' ? pathname === withBase('/') : pathname.startsWith(withBase(item.href)) }} href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>
    <button class="menu-toggle" type="button" aria-label="打开导航菜单" aria-expanded="false"><span>菜单</span><i aria-hidden="true"></i></button>
    <button class="drawer-backdrop" type="button" aria-label="关闭导航菜单"></button>
    <a class="contact" href={site.github} target="_blank" rel="noreferrer">代码仓库 ↗</a>
  </div>
</header>
<style>
  .site-header { position: sticky; top: 0; z-index: 20; background: rgba(255,255,255,.88); backdrop-filter: blur(18px); box-shadow: 0 8px 28px rgba(20,40,30,.035); }
  .nav-wrap { min-height: 76px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .brand { position:relative; display: inline-flex; align-items: center; gap: 14px; }
  .brand-mark { position: relative; display: block; flex: 0 0 auto; width: 46px; height: 46px; }
  .brand-mark img { display: block; width: 100%; height: 100%; }
  .brand-copy { display: flex; min-height: 46px; flex-direction: column; justify-content: center; }
  .brand-copy strong { color: var(--ink); font-size: 1rem; line-height: 1.2; font-weight: 760; letter-spacing: -.015em; }
  .brand-copy small { margin-top: 5px; color: var(--muted); font-size: .74rem; line-height: 1.35; font-weight: 500; letter-spacing: .01em; white-space: nowrap; }
  nav { display: flex; align-items: center; gap: 4px; }
  nav a { position: relative; padding: 8px 12px; color: var(--muted); font-size: .9rem; }
  nav a::after { content: ''; position: absolute; left: 12px; right: 12px; bottom: 3px; height: 2px; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform .2s cubic-bezier(.2,.8,.2,1); }
  nav a:hover, nav a.active { color: var(--ink); }
  nav a:hover::after, nav a.active::after { transform: scaleX(1); }
  .contact { font-size: .9rem; font-weight: 700; }
  .menu-toggle,.drawer-backdrop{display:none}
  @media (min-width: 761px) {
    nav a{overflow:hidden;border-radius:12px;transition:color .28s var(--ease-out),background .32s var(--ease-out),transform .32s var(--ease-out),box-shadow .32s var(--ease-out)}
    nav a::before{display:none}
    nav a::after{left:50%;right:auto;bottom:5px;width:20px;height:2px;border-radius:8px;background:linear-gradient(90deg,var(--accent),var(--warm));transform:translateX(-50%) scaleX(0);transform-origin:center;transition:transform .32s var(--ease-out),width .32s var(--ease-out)}
    nav a:hover{color:#126f50;background:linear-gradient(135deg,rgba(232,248,240,.92),rgba(241,239,255,.72));transform:translateY(-2px);box-shadow:0 9px 22px rgba(28,88,63,.08)}
    nav a:hover::after{width:28px;transform:translateX(-50%) scaleX(1)}
    nav a.active{color:var(--ink);background:rgba(241,248,244,.72)}
    nav a.active::after{width:24px;transform:translateX(-50%) scaleX(1)}
  }
  @media (max-width: 760px) { .site-header{z-index:40;padding-top:env(safe-area-inset-top);background:rgba(255,255,255,.92);box-shadow:0 10px 34px rgba(24,58,43,.07)}.nav-wrap{min-height:70px;gap:12px}.season-edge{left:18px;top:-6px;transform:scale(.8);opacity:.5}.contact{display:none}.brand{position:relative;z-index:3;min-width:0;gap:9px}.brand-mark{width:38px;height:38px;filter:drop-shadow(0 8px 14px rgba(51,68,210,.14))}.brand-copy{display:flex;min-height:38px}.brand-copy strong{font-size:.86rem}.brand-copy small{display:block;margin-top:3px;font-size:.65rem}nav{position:fixed;z-index:4;top:0;right:0;display:flex;width:100vw;max-width:none;height:100dvh;padding:92px 22px 30px;align-items:stretch;justify-content:flex-start;flex-direction:column;gap:7px;background:linear-gradient(160deg,#fff 0%,#f3faf6 58%,#f5f2ff 100%);box-shadow:-24px 0 70px rgba(18,43,32,.16);visibility:hidden;opacity:0;pointer-events:none;clip-path:inset(0 0 0 100%);transition:clip-path .32s cubic-bezier(.2,.8,.2,1),opacity .2s,visibility 0s linear .32s}nav a{display:flex;align-items:center;min-height:52px;padding:0 18px;border-radius:13px;color:#4d5550;font-size:.94rem;font-weight:620}nav a::after{display:none}nav a:hover,nav a.active{color:var(--accent);background:#fff;box-shadow:0 10px 28px rgba(26,72,52,.08)}.menu-toggle{position:relative;z-index:5;display:grid;place-items:center;width:42px;min-height:42px;margin-left:auto;padding:0;border:0;border-radius:12px;color:var(--ink);background:#f1f7f4}.menu-toggle>span{display:none}.menu-toggle i,.menu-toggle i::before,.menu-toggle i::after{display:block;width:17px;height:2px;border-radius:9px;background:currentColor;transition:transform .25s,opacity .25s}.menu-toggle i{position:relative}.menu-toggle i::before,.menu-toggle i::after{content:'';position:absolute;left:0}.menu-toggle i::before{top:-5px}.menu-toggle i::after{top:5px}.drawer-backdrop{position:fixed;z-index:1;inset:0;display:block;border:0;background:rgba(13,20,17,.28);opacity:0;pointer-events:none;backdrop-filter:blur(3px);transition:opacity .25s}.site-header.menu-open nav{visibility:visible;opacity:1;pointer-events:auto;clip-path:inset(0);transition-delay:0s}.site-header.menu-open .drawer-backdrop{opacity:1;pointer-events:auto}.site-header.menu-open .season-edge{opacity:0}.site-header.menu-open .drawer-backdrop{opacity:1;pointer-events:auto}.site-header.menu-open .menu-toggle{background:#fff;box-shadow:0 8px 24px rgba(26,72,52,.1)}.site-header.menu-open .menu-toggle i{background:transparent}.site-header.menu-open .menu-toggle i::before{top:0;transform:rotate(45deg)}.site-header.menu-open .menu-toggle i::after{top:0;transform:rotate(-45deg)} }
  @media (max-width: 390px) { .nav-wrap{min-height:66px;gap:7px}.brand{gap:7px}.brand-mark{width:34px;height:34px}.brand-copy{min-height:34px}.brand-copy strong{font-size:.8rem}.brand-copy small{font-size:.61rem}.menu-toggle{width:40px;min-height:40px} }
</style>
<script>
  const header = document.querySelector<HTMLElement>('.site-header');
  const toggle = header?.querySelector<HTMLButtonElement>('.menu-toggle');
  const backdrop = header?.querySelector<HTMLButtonElement>('.drawer-backdrop');
  let lockedScrollY = 0;
  let scrollLocked = false;
  const lockScroll = () => {
    if (scrollLocked) return;
    lockedScrollY = window.scrollY;
    scrollLocked = true;
    document.documentElement.style.overflow = 'hidden';
    document.documentElement.style.overscrollBehavior = 'none';
    document.body.style.position = 'fixed';
    document.body.style.top = `-${lockedScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.width = '100%';
    document.body.style.overflow = 'hidden';
    document.body.style.touchAction = 'none';
  };
  const unlockScroll = () => {
    if (!scrollLocked) return;
    document.documentElement.style.overflow = '';
    document.documentElement.style.overscrollBehavior = '';
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.width = '';
    document.body.style.overflow = '';
    document.body.style.touchAction = '';
    window.scrollTo(0, lockedScrollY);
    scrollLocked = false;
  };
  const closeMenu = () => { header?.classList.remove('menu-open'); toggle?.setAttribute('aria-expanded', 'false'); unlockScroll(); };
  closeMenu();
  toggle?.addEventListener('click', () => { const open = !header?.classList.contains('menu-open'); header?.classList.toggle('menu-open', open); toggle.setAttribute('aria-expanded', String(open)); open ? lockScroll() : unlockScroll(); });
  backdrop?.addEventListener('click', closeMenu);
  header?.querySelectorAll('nav a').forEach((link) => link.addEventListener('click', closeMenu));
  window.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeMenu(); });
</script>
