---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../data/site';
interface Props { project: CollectionEntry<'projects'>; index?: number; }
const { project, index = 0 } = Astro.props;
---
<article class="project card" data-tilt>
  <a href={withBase(`/projects/${project.id}/`)} aria-label={`查看项目：${project.data.title}`}>
    <div class="visual" data-index={String(index + 1).padStart(2, '0')}>
      <div class="orbit"></div><span>{project.data.year}</span>
    </div>
    <div class="body">
      <div class="meta"><span>{project.data.status}</span><span>{project.data.role}</span></div>
      <h3>{project.data.title}</h3>
      <p>{project.data.summary}</p>
      <div class="tags">{project.data.stack.map((item) => <span class="tag">{item}</span>)}</div>
      <strong>查看项目 →</strong>
    </div>
  </a>
</article>
<style>
  .project { grid-column: span 6; overflow: hidden; }
  .project a { height: 100%; display: grid; grid-template-columns: minmax(150px, .8fr) 1.2fr; }
  .visual { min-height: 220px; display: flex; align-items: end; justify-content: space-between; padding: 20px; color: white; background: #211724; position: relative; overflow: hidden; }
  .visual::after { content: ''; position: absolute; inset: 0; opacity: .55; background: radial-gradient(circle at 76% 22%, #ff5b35, transparent 31%), radial-gradient(circle at 20% 85%, #6d5dfc, transparent 36%), linear-gradient(rgba(255,255,255,.09) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.09) 1px, transparent 1px); background-size: auto, auto, 22px 22px, 22px 22px; transition: transform .4s ease; }
  .project:hover .visual::after { transform: scale(1.08) rotate(1deg); }
  .visual > * { position: relative; z-index: 1; }
  .visual::before { content: attr(data-index); position: absolute; top: -30px; right: -8px; font-size: 8rem; line-height: 1; font-weight: 800; letter-spacing: -.08em; opacity: .11; }
  .orbit { position: absolute; width: 190px; height: 190px; left: -50px; top: 55px; border: 1px solid rgba(255,255,255,.45); border-radius: 50%; }
  .orbit::after { content: ''; position: absolute; width: 18px; height: 18px; right: 14px; top: 20px; background: var(--warm); border-radius: 50%; box-shadow: 0 0 25px rgba(223,255,87,.65); }
  .body { padding: 22px; }
  .meta { display: flex; justify-content: flex-start; align-items: center; gap: 8px; flex-wrap: wrap; color: var(--muted); font-family: "Noto Sans SC Variable", sans-serif; font-size: .76rem; }
  .meta span { display: inline-flex; align-items: center; min-height: 29px; padding: 5px 10px; border-radius: 9px; color: #5a655f; background: #f1f7f4; line-height: 1.35; }
  .meta span:first-child { gap: 7px; color: #147553; background: #e8f8f0; font-weight: 650; }
  .meta span:first-child::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: #36b97f; box-shadow: 0 0 0 4px rgba(54,185,127,.1); }
  .meta span:last-child { color: #625d8c; background: #f1efff; }
  h3 { margin: 16px 0 9px; font-size: 1.35rem; line-height: 1.2; letter-spacing: -.035em; }
  p { color: var(--muted); }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; margin: 16px 0 21px; }
  strong { color: var(--accent); font-size: .9rem; }
  @media (max-width: 900px) { .project { grid-column: span 12; } }
  @media (max-width: 540px) { .project a { display: block; } .visual { min-height: 185px;padding:17px;background:linear-gradient(145deg,#18251f,#17151f) }.visual::before{font-size:6rem}.body{padding:20px;background:linear-gradient(180deg,#fff,#f9fcfa)}.meta{justify-content:flex-start;gap:7px;flex-wrap:wrap;font-family:"Noto Sans SC Variable",sans-serif}.meta span{display:inline-flex;align-items:center;min-height:28px;padding:5px 9px;border-radius:8px;background:#f1f7f4;color:#4f5c55;font-size:.72rem;line-height:1.35}.meta span:first-child{gap:6px;color:#137653;background:#eaf8f1;font-weight:650}.meta span:first-child::before{content:'';width:6px;height:6px;border-radius:50%;background:#35b77d}.meta span:last-child{color:#635d91;background:#f2f0ff}h3{margin-top:15px;font-size:1.3rem}p{font-size:.9rem;line-height:1.7}.tags{margin-block:14px 18px} }
</style>
