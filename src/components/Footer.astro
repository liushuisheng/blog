---
import { site, withBase } from '../data/site';
---
<footer>
  <div class="container footer-main">
    <a class="footer-brand" href={withBase('/')}>
      <img src={withBase('/brand-logo-transparent.png')} alt="" />
      <span><strong>AI进化日记</strong><small>记录AI学习 · 探索AI应用</small></span>
    </a>

    <nav aria-label="页脚导航">
      <a href={withBase('/projects/')}>作品</a>
      <a href={withBase('/articles/')}>文章</a>
      <a href={withBase('/about/')}>关于</a>
      <a href={site.github}>代码仓库 ↗</a>
      <a href={withBase('/rss.xml')}>订阅</a>
    </nav>
  </div>
  <div class="container footer-bottom">
    <span>© {new Date().getFullYear()} 刘水生的技术博客</span>
    <span>内容与代码持续更新</span>
  </div>
</footer>

<style>
  footer { color: var(--ink); background: #f5fbf7; }
  .footer-main { display: flex; align-items: center; justify-content: space-between; gap: 50px; min-height: 128px; padding-block: 28px; }
  .footer-brand { display: inline-flex; align-items: center; gap: 14px; flex: 0 0 auto; }
  .footer-brand img { display: block; width: 48px; height: 48px; object-fit: contain; }
  .footer-brand>span { display: flex; min-height: 48px; flex-direction: column; justify-content: center; }
  .footer-brand strong { font-size: 1rem; line-height: 1.2; font-weight: 700; letter-spacing: 0; }
  .footer-brand small { margin-top: 5px; color: var(--muted); font-size: .74rem; line-height: 1.35; font-weight: 500; letter-spacing: .01em; }
  nav { display: flex; align-items: center; justify-content: flex-end; gap: clamp(18px,3vw,38px); }
  nav a { position: relative; color: #404641; font-size: .83rem; font-weight: 500; white-space: nowrap; }
  nav a::after { content: ''; position: absolute; left: 0; right: 0; bottom: -5px; height: 1px; background: var(--accent); transform: scaleX(0); transform-origin: left; transition: transform .2s ease; }
  nav a:hover { color: var(--accent); } nav a:hover::after { transform: scaleX(1); }
  .footer-bottom { display: flex; align-items: center; justify-content: space-between; padding-block: 10px 20px; color: #747b76; font-size: .75rem; line-height: 1.5; }
  @media(max-width:720px){footer{border-radius:26px 26px 0 0;background:linear-gradient(145deg,#f4fbf7,#f8f7ff 62%,#fbfff5)}.footer-main{align-items:center;flex-direction:column;gap:14px;min-height:0;padding-block:24px 8px}.footer-brand{gap:11px}.footer-brand img{width:40px;height:40px}.footer-brand>span{min-height:40px}.footer-brand strong{font-size:.94rem}.footer-brand small{margin-top:3px;font-size:.7rem}nav{width:100%;justify-content:center;flex-wrap:wrap;gap:0 17px}nav a{display:flex;align-items:center;min-height:36px;font-size:.78rem}.footer-bottom{justify-content:center;gap:7px;flex-direction:row;flex-wrap:wrap;padding-block:8px 20px;text-align:center;font-size:.7rem}.footer-bottom span+span::before{content:'·';margin-right:7px;color:#a2aaa5}}
  @media(max-width:370px){nav{gap-inline:12px}.footer-bottom{flex-direction:column;gap:2px}.footer-bottom span+span::before{display:none}}
</style>
