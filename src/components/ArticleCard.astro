---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../data/site';
interface Props { post: CollectionEntry<'blog'>; }
const { post } = Astro.props;
const date = post.data.updatedAt ?? post.data.publishedAt;
---
<article class="article-card card" data-tilt>
  <div class="date"><span>{date.getFullYear()}</span><strong>{String(date.getMonth() + 1).padStart(2, '0')}.{String(date.getDate()).padStart(2, '0')}</strong></div>
  <div>
    <div class="tags">{post.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}</div>
    <h3><a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a></h3>
    <p>{post.data.description}</p>
  </div>
</article>
<style>
  .article-card { position: relative; isolation: isolate; overflow: hidden; grid-column: span 6; min-height: 205px; padding: 28px; display: grid; grid-template-columns: 88px 1fr; gap: 24px; background: linear-gradient(145deg,#fff 18%,#f5fbf8 100%); box-shadow: 0 20px 52px rgba(29,68,51,.075); transition: transform .24s ease,box-shadow .24s ease; }
  .article-card:nth-child(even){background:linear-gradient(145deg,#fff 18%,#f7f5ff 100%)}
  .article-card::before{content:'';position:absolute;z-index:-1;width:120px;height:120px;right:-52px;top:-58px;border-radius:42% 58% 55% 45%;background:linear-gradient(135deg,rgba(189,241,107,.3),rgba(91,211,170,.08));transform:rotate(18deg);transition:transform .3s ease}
  .article-card:nth-child(even)::before{background:linear-gradient(135deg,rgba(107,99,232,.19),rgba(120,183,255,.08))}
  .article-card::after{content:'↗';position:absolute;right:22px;top:22px;display:grid;place-items:center;width:34px;height:34px;border-radius:11px;color:var(--accent);background:rgba(255,255,255,.82);box-shadow:0 8px 22px rgba(29,68,51,.07);font-size:.86rem;font-weight:700;opacity:.72;transition:opacity .2s,transform .2s}
  .article-card:hover{transform:translateY(-4px);box-shadow:0 27px 62px rgba(29,68,51,.11)}.article-card:hover::before{transform:rotate(24deg) scale(1.08)}.article-card:hover::after{opacity:1;transform:translate(2px,-2px)}
  .date { position:relative;align-self:start;display:flex;flex-direction:column;padding:4px 0 4px 14px;color:var(--muted);font-size:.72rem; }
  .date::before{content:'';position:absolute;left:0;top:5px;bottom:5px;width:4px;border-radius:99px;background:linear-gradient(180deg,var(--accent),var(--warm));box-shadow:0 5px 14px rgba(20,134,95,.16)}
  .article-card:nth-child(even) .date::before{background:linear-gradient(180deg,#6b63e8,#78b7ff);box-shadow:0 5px 14px rgba(107,99,232,.15)}
  .date span{letter-spacing:.07em}.date strong { color: var(--ink); font-size: 1.08rem;line-height:1.35; }
  .tags { display: flex;flex-wrap:wrap;gap:6px;padding-right:48px;color:var(--accent);font-size:.72rem;font-weight:700; }
  .tags span{padding:5px 8px;border-radius:8px;color:#137653;background:rgba(234,248,241,.88)}
  .article-card:nth-child(even) .tags span{color:#625d8c;background:rgba(239,237,255,.9)}
  h3 { margin: 13px 0 8px; font-size: 1.3rem; line-height: 1.35; letter-spacing: -.025em; }
  h3 a:hover { color: var(--accent); }
  p { margin: 0; color: var(--muted); font-size: .92rem; }
  @media (max-width: 760px) { .article-card { grid-column: span 12; padding: 21px; } }
  @media (max-width: 520px) { .article-card{position:relative;isolation:isolate;overflow:hidden;grid-template-columns:1fr;gap:16px;min-height:225px;padding:22px;border-radius:22px;background:linear-gradient(145deg,#fff 12%,#f5fbf8 100%);box-shadow:0 20px 52px rgba(29,68,51,.09);transition:transform .22s ease,box-shadow .22s ease}.article-card::before{content:'';position:absolute;z-index:-1;width:125px;height:125px;right:-48px;top:-52px;border-radius:38% 62% 55% 45%;background:linear-gradient(135deg,rgba(189,241,107,.42),rgba(91,211,170,.13));transform:rotate(18deg)}.article-card::after{content:'↗';position:absolute;right:18px;top:19px;display:grid;place-items:center;width:34px;height:34px;border-radius:11px;color:var(--accent);background:rgba(255,255,255,.82);box-shadow:0 8px 24px rgba(29,68,51,.08);font-size:.9rem;font-weight:700}.article-card:nth-child(even){background:linear-gradient(145deg,#fff 12%,#f7f5ff 100%)}.article-card:nth-child(even)::before{background:linear-gradient(135deg,rgba(107,99,232,.27),rgba(120,183,255,.12))}.article-card:active{transform:scale(.985);box-shadow:0 12px 34px rgba(29,68,51,.07)}.date{position:relative;width:max-content;min-height:48px;flex-direction:column;align-items:flex-start;justify-content:center;gap:0;padding:3px 0 3px 13px;border:0;background:none;color:#718078}.date::before{content:'';position:absolute;left:0;top:5px;bottom:5px;width:4px;border-radius:99px;background:linear-gradient(180deg,var(--accent),var(--warm));box-shadow:0 5px 14px rgba(20,134,95,.2)}.article-card:nth-child(even) .date::before{background:linear-gradient(180deg,#6b63e8,#78b7ff);box-shadow:0 5px 14px rgba(107,99,232,.18)}.date span{font-size:.66rem;line-height:1.25;letter-spacing:.08em}.date strong{color:var(--ink);font-size:1.06rem;line-height:1.3;letter-spacing:.015em}.tags{position:relative;z-index:1;flex-wrap:wrap;gap:6px;margin-top:2px}.tags span{padding:4px 8px;border-radius:7px;color:#137653;background:rgba(234,248,241,.9);font-size:.7rem}h3{max-width:90%;margin:10px 0 7px;font-size:1.24rem;line-height:1.4;letter-spacing:-.02em}p{margin-top:0;font-size:.88rem;line-height:1.75} }
</style>
