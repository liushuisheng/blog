---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { site } from '../data/site';

interface Props { title?: string; description?: string; image?: string; type?: 'website' | 'article'; }
const { title = site.title, description = site.description, image, type = 'website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const fullTitle = title === site.title ? title : `${title} · ${site.name}`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'BlogPosting' : 'WebSite',
  name: fullTitle,
  headline: fullTitle,
  description,
  url: canonical,
  author: { '@type': 'Person', name: site.name, url: `${site.url}/about/` }
};
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/png" href="/brand-logo-transparent.png" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={site.title} href={`${site.url}/rss.xml`} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {image && <meta property="og:image" content={new URL(image, site.url).toString()} />}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="page-progress" aria-hidden="true"><i></i></div>
    <div class="cursor-glow" aria-hidden="true"></div>
    <Header />
    <main><slot /></main>
    <Footer />
    <script>
      const pageProgress = document.querySelector<HTMLElement>('.page-progress');
      const progressBar = pageProgress?.querySelector<HTMLElement>('i');
      const startProgress = () => {
        if (!pageProgress || !progressBar) return;
        pageProgress.classList.remove('is-done');
        pageProgress.classList.remove('is-finishing');
        pageProgress.classList.add('is-loading');
        progressBar.style.transform = 'scaleX(.72)';
      };
      const finishProgress = () => {
        if (!pageProgress || !progressBar) return;
        const currentTransform = window.getComputedStyle(progressBar).transform;
        progressBar.style.transform = currentTransform;
        pageProgress.classList.add('is-finishing');
        void progressBar.offsetWidth;
        let finished = false;
        const hideProgress = () => {
          if (finished) return;
          finished = true;
          pageProgress.classList.add('is-done');
          pageProgress.classList.remove('is-loading');
          pageProgress.classList.remove('is-finishing');
        };
        progressBar.addEventListener('transitionend', (event) => {
          if (event.propertyName === 'transform') hideProgress();
        }, { once: true });
        requestAnimationFrame(() => {
          progressBar.style.transform = 'scaleX(1)';
        });
        window.setTimeout(hideProgress, 900);
      };
      document.addEventListener('click', (event) => {
        const link = (event.target as Element).closest<HTMLAnchorElement>('a[href]');
        if (!link || link.target === '_blank' || link.hasAttribute('download') || event.defaultPrevented) return;
        const target = new URL(link.href, window.location.href);
        if (target.origin === window.location.origin && target.href !== window.location.href) startProgress();
      });
      if (document.readyState === 'complete') finishProgress();
      else window.addEventListener('load', finishProgress, { once: true });

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduceMotion) {
        const glow = document.querySelector<HTMLElement>('.cursor-glow');
        const finePointer = window.matchMedia('(pointer: fine)').matches;
        if (glow && finePointer) {
          window.addEventListener('pointermove', (event) => {
            glow.style.left = `${event.clientX}px`;
            glow.style.top = `${event.clientY}px`;
            glow.style.opacity = '1';
          }, { passive: true });
          document.documentElement.addEventListener('mouseleave', () => glow.style.opacity = '0');
        }
        const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }), { threshold: .1 });
        document.querySelectorAll('.reveal').forEach((node) => observer.observe(node));
        if (window.matchMedia('(min-width: 761px)').matches) {
          document.querySelectorAll<HTMLElement>('[data-tilt]').forEach((card) => {
            card.addEventListener('pointermove', (event) => {
              const rect = card.getBoundingClientRect();
              const x = (event.clientX - rect.left) / rect.width - .5;
              const y = (event.clientY - rect.top) / rect.height - .5;
              card.style.transform = `perspective(900px) rotateX(${-y * 3}deg) rotateY(${x * 3}deg) translateY(-3px)`;
            });
            card.addEventListener('pointerleave', () => card.style.transform = '');
          });

          const parallaxItems = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax]')).map((element) => ({
            element,
            depth: Number(element.dataset.parallax ?? 0),
            current: 0,
            target: 0
          }));
          if (parallaxItems.length && window.matchMedia('(min-width: 761px)').matches) {
            let parallaxFrame = 0;
            let parallaxActive = true;
            const measureParallax = () => {
              const viewportCenter = window.innerHeight / 2;
              parallaxItems.forEach((item) => {
                const rect = item.element.getBoundingClientRect();
                const elementCenter = rect.top - item.current + rect.height / 2;
                item.target = Math.max(-80, Math.min(80, (elementCenter - viewportCenter) * item.depth));
              });
              if (!parallaxFrame) parallaxFrame = requestAnimationFrame(renderParallax);
            };
            const renderParallax = () => {
              parallaxFrame = 0;
              let moving = false;
              parallaxItems.forEach((item) => {
                item.current += (item.target - item.current) * .18;
                if (Math.abs(item.target - item.current) > .08) moving = true;
                item.element.style.setProperty('--parallax-y', `${item.current.toFixed(2)}px`);
              });
              if (moving && parallaxActive) parallaxFrame = requestAnimationFrame(renderParallax);
            };
            window.addEventListener('scroll', measureParallax, { passive: true });
            window.addEventListener('resize', measureParallax, { passive: true });
            document.addEventListener('visibilitychange', () => {
              parallaxActive = !document.hidden;
              if (parallaxActive) measureParallax();
            });
            measureParallax();
          }
        }
      } else {
        document.querySelectorAll('.reveal').forEach((node) => node.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
